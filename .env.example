# India PreValidate API — Environment Variables
# Copy this to .env and fill in values

# Server
PORT=8000
RATE_LIMIT_PER_MIN=60

# Redis for rate limiting & caching (optional, replaces in-memory store)
# REDIS_URL=redis://localhost:6379

# Note: This API performs OFFLINE format validation only.
# It does NOT connect to GSTN, NSDL, NPCI, or any government system.
# No government API keys are needed.
